{
  "name": "vite-electron-base",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir -c electron-builder.config.mjs",
    "build:win": "npm run build && electron-builder --win -c electron-builder.config.mjs",
    "build:mac": "npm run build && electron-builder --mac -c electron-builder.config.mjs",
    "build:linux": "npm run build && electron-builder --linux -c electron-builder.config.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vueuse/core": "^14.3.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.18.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "element-plus": "^2.14.2",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss": "^8.5.15",
    "postcss-px-to-viewport-8-plugin": "^1.1.5",
    "prettier": "^3.7.4",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.1.6"
  },
  "lint-staged": {
    "*.{ts,mts,tsx,vue}": "eslint --fix",
    "*.{ts,mts,tsx,vue,json,md,yml,yaml,css,scss,html}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "vite": "7.3.5",
      "@types/node": "22.20.0"
    }
  }
}
